PORT=5000
MONGO_URI=mongodb://localhost:27017/timecapsule
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# JWT Secrets
# Run this twice to generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_access_token_secret
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Email Settings (Brevo API)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=xkeysib-your-brevo-api-key-here
EMAIL_FROM=your_gmail@gmail.com

# Cloudinary Settings (OPTIONAL — only for media uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
